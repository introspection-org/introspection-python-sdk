# Introspection SDK
INTROSPECTION_TOKEN=your_introspection_token
INTROSPECTION_BASE_URL=https://otel.introspection.dev

# OpenAI (for OpenAI-based examples)
OPENAI_API_KEY=your_openai_api_key

# Arize/Phoenix (optional)
ARIZE_SPACE_KEY=your_arize_space_key
ARIZE_API_KEY=your_arize_api_key

# Braintrust (optional)
BRAINTRUST_API_KEY=your_braintrust_api_key

# Langchain (optional)
LANGCHAIN_API_KEY=your_langchain_api_key

# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
# Set to https://us.cloud.langfuse.com for US region; defaults to EU
LANGFUSE_BASE_URL=https://cloud.langfuse.com
